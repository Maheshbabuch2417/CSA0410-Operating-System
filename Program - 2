#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
int main()
{
    int s, d, n;
    char buf[100];

    s = open("source.txt", O_RDONLY);
    d = open("destination.txt", O_CREAT | O_WRONLY | O_TRUNC, 0644);

    while((n = read(s, buf, 100)) > 0)
        write(d, buf, n);

    close(s);
    close(d);

    printf("File copied successfully.\n");

    return 0;
}
