#include <stdio.h>
#include <string.h>
#include <sys/ipc.h>
#include <sys/msg.h>

struct msgbuf
{
    long type;
    char text[100];
};

int main()
{
    struct msgbuf msg;
    int msgid;

    msgid = msgget(1234, 0666 | IPC_CREAT);

    msg.type = 1;

    printf("Enter a message: ");
    scanf("%s", msg.text);

    msgsnd(msgid, &msg, sizeof(msg.text), 0);
    msgrcv(msgid, &msg, sizeof(msg.text), 1, 0);

    printf("Received Message: %s\n", msg.text);

    msgctl(msgid, IPC_RMID, NULL);

    return 0;
}
