#include <stdio.h>

int main()
{
    int n, bt[10], rt[10], tq;
    int i, remain;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        printf("Enter Burst Time of P%d: ",i+1);
        scanf("%d",&bt[i]);
        rt[i]=bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d",&tq);

    remain=n;

    printf("\nExecution Order:\n");

    while(remain>0)
    {
        for(i=0;i<n;i++)
        {
            if(rt[i]>0)
            {
                if(rt[i]<=tq)
                {
                    printf("P%d ",i+1);
                    rt[i]=0;
                    remain--;
                }
                else
                {
                    printf("P%d ",i+1);
                    rt[i]-=tq;
                }
            }
        }
    }
    return 0;
}
