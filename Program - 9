#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>

int main()
{
    int shmid;
    char *str;

    shmid = shmget(1234, 100, 0666 | IPC_CREAT);
    str = (char *)shmat(shmid, NULL, 0);

    printf("Enter a message: ");
    scanf("%s", str);

    printf("Message in Shared Memory: %s\n", str);

    shmdt(str);
    shmctl(shmid, IPC_RMID, NULL);

    return 0;
}
